# Polygon wallet private key (for signing orders)
POLYMARKET_PK=

# Funder/proxy wallet address (holds your USDC on Polymarket)
POLYMARKET_FUNDER=

# Optional: Polygon RPC (for on-chain monitoring)
POLYGON_RPC_URL=https://polygon-rpc.com

# Optional: Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bot settings
DRY_RUN=true
INITIAL_BANKROLL=1000
DB_PATH=trades.db
